---
// src/pages/thank-you.astro
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Navbar from '../components/sections/Navbar.astro';
import Footer from '../components/sections/Footer.astro';
import Button from '@components/ui/Button.astro';

const breadcrumbItems = [
  { name: 'Home', item: '/' },
  { name: 'Thank You', item: '/thank-you' }
];
---

<Layout 
  title="Demo Request Confirmed | Hyperprobe" 
  description="Thank you for requesting a Hyperprobe product demo. Our engineering team has received your application and will follow up shortly."
  schemaTypes={['Breadcrumb']}
  breadcrumbItems={breadcrumbItems}
>
  <Navbar />

  <main class="flex-grow relative z-10 px-4 sm:px-6 lg:px-8 py-12 md:py-20 max-w-7xl mx-auto w-full">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      
      <!-- Left Column: Confirmation message -->
      <div class="lg:col-span-5 flex flex-col space-y-6 text-left">
        <!-- Success Icon -->
        <div class="relative w-16 h-16 rounded-full bg-emerald-50 border border-emerald-200 flex items-center justify-center animate-pulse-slow">
          <!-- Inside glow dot -->
          <div class="absolute inset-2 rounded-full bg-emerald-100/50 blur-md"></div>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-emerald-700 relative z-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        </div>

        <!-- Heading -->
        <h1 class="text-3xl sm:text-4xl font-normal text-zinc-900 tracking-tight font-serif leading-tight">
          Thanks! Your request <br />
          <span class="text-brand-primary italic">has been received.</span>
        </h1>

        <!-- Description -->
        <p class="text-zinc-500 text-sm font-light leading-relaxed max-w-md">
          Our engineering team has received your application. To expedite the process, please pick a convenient time slot on the scheduler to book your live stack-focused walkthrough.
        </p>

        <!-- Return Button -->
        <div class="flex flex-col sm:flex-row gap-3 pt-4">
          <Button href="/" variant="primary" size="lg" class="w-full sm:w-auto font-bold">
            Return to Homepage
          </Button>
          <Button href="/#why-hyperprobe" variant="outline" size="lg" class="w-full sm:w-auto text-zinc-500">
            Explore Details
          </Button>
        </div>
      </div>

      <!-- Right Column: Calendly Embed -->
      <div class="lg:col-span-7 w-full">
        <div class="rounded-2xl border border-zinc-200 bg-white overflow-hidden shadow-md h-[680px]">
          <iframe
            src="https://calendly.com/shailendra-gco-hypertest/shailendra-1-1"
            width="100%"
            height="100%"
            frameborder="0"
            style="border:none;"
          ></iframe>
        </div>
      </div>

    </div>
  </main>

  <Footer />
</Layout>
