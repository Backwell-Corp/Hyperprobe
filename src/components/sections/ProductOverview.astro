---
// src/components/sections/ProductOverview.astro
---

<section id="product-overview" class="relative z-10 bg-white">
  <div class="max-w-[1380px] mx-auto px-6 py-16 md:px-16 md:py-[100px]">
    
    <!-- Section Heading (Matches screenshot) -->
    <div class="text-left max-w-5xl mb-16">
      <span class="eyebrow block mb-3">— THE SOLUTION</span>
      <h2 class="section-heading mb-4">
        Real evidence.<br class="hidden sm:inline" />
        <span class="accent">No redeploys.</span>
      </h2>
      <p class="body-text">
        Install the SDK once. When an incident fires, your coding agent picks the suspect line and tells HyperProbe to probe it. The SDK captures the exact variable state from your running service and hands it back. <span class="text-brand-primary font-medium">Your agent diagnoses from facts, not guesses.</span>
      </p>
    </div>

    <!-- 3 Step Columns (Matches screenshot) -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 items-stretch max-w-6xl mx-auto">
      
      <!-- Step 1: Install the Agent -->
      <div class="rounded-[20px] border border-zinc-200 bg-white overflow-hidden shadow-sm flex flex-col justify-between min-h-[540px] pb-6">
        <!-- Orange-red Header -->
        <div class="bg-[#C0392B] py-3.5 text-center">
          <span class="text-white font-mono font-bold tracking-widest text-[11px] uppercase">
            STEP 01
          </span>
        </div>

        <div class="p-6 flex flex-col justify-between flex-grow space-y-6">
          <h3 class="text-xl font-bold text-zinc-900 font-serif text-center mt-1">
            Install the Agent
          </h3>

          <!-- Visual: pom.xml Mockup -->
          <div class="rounded-[12px] border border-zinc-800 bg-[#121824] overflow-hidden text-left font-mono text-[11px] leading-relaxed shadow-inner">
            <!-- Title Bar -->
            <div class="bg-[#0B0F17] px-4 py-2 flex items-center justify-between border-b border-zinc-900 select-none">
              <div class="flex gap-1.5">
                <span class="w-2.5 h-2.5 rounded-full bg-[#EF4444] inline-block"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-[#F59E0B] inline-block"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-[#10B981] inline-block"></span>
              </div>
              <span class="text-zinc-500 font-mono text-[10px] pr-2">pom.xml</span>
            </div>
            <!-- Code Area -->
            <div class="p-4 text-zinc-400 space-y-0.5">
              <p class="text-zinc-600">&lt;dependency&gt;</p>
              <p class="pl-4 text-zinc-400">&lt;groupId&gt;<span class="text-zinc-300">io.hyperprobe</span>&lt;/groupId&gt;</p>
              <p class="pl-4 text-zinc-400">&lt;artifactId&gt;<span class="text-[#3b82f6]">agent</span>&lt;/artifactId&gt;</p>
              <p class="pl-4 text-zinc-400">&lt;scope&gt;<span class="text-emerald-500">runtime</span>&lt;/scope&gt;</p>
              <p class="text-zinc-600">&lt;/dependency&gt;</p>
            </div>
          </div>

          <p class="text-zinc-500 text-xs sm:text-sm font-light leading-relaxed text-center px-2">
            Add the SDK dependency, instrument your service, deploy. Commit once — never touch it again.
          </p>

          <!-- Bottom check badge -->
          <div class="rounded-lg border border-emerald-100 bg-emerald-50/40 text-[#0F766E] py-2 text-center text-xs font-bold font-sans">
            ✓ One-time setup per service
          </div>
        </div>
      </div>

      <!-- Step 2: Set a Breakpoint from IDE -->
      <div class="rounded-[20px] border border-zinc-200 bg-white overflow-hidden shadow-sm flex flex-col justify-between min-h-[540px] pb-6">
        <!-- Orange-red Header -->
        <div class="bg-[#C0392B] py-3.5 text-center">
          <span class="text-white font-mono font-bold tracking-widest text-[11px] uppercase">
            STEP 02
          </span>
        </div>

        <div class="p-6 flex flex-col justify-between flex-grow space-y-6">
          <h3 class="text-xl font-bold text-zinc-900 font-serif text-center mt-1">
            Set a Breakpoint from IDE
          </h3>

          <!-- Visual: PaymentService.java Mockup -->
          <div class="rounded-[12px] border border-zinc-800 bg-[#121824] overflow-hidden text-left font-mono text-[11px] leading-relaxed shadow-inner">
            <!-- Title Bar -->
            <div class="bg-[#0B0F17] px-4 py-2 flex items-center justify-between border-b border-zinc-900 select-none">
              <div class="flex gap-1.5">
                <span class="w-2.5 h-2.5 rounded-full bg-[#EF4444] inline-block"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-[#F59E0B] inline-block"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-[#10B981] inline-block"></span>
              </div>
              <span class="text-zinc-500 font-mono text-[10px] pr-2">PaymentService.java</span>
            </div>
            <!-- Code Area -->
            <div class="py-4 text-zinc-400 font-mono">
              <div class="px-4 text-zinc-500"><span class="w-6 inline-block select-none">32</span> public void <span class="text-zinc-300">process</span>(Order o) &lbrace;</div>
              <div class="px-4 text-zinc-500"><span class="w-6 inline-block select-none">33</span>   Balance b = getBalance(o);</div>
              <!-- Highlighted breakpoint line -->
              <div class="bg-red-950/30 border-l-2 border-red-600 px-4 py-0.5 text-zinc-300 flex items-center">
                <span class="w-6 inline-block select-none text-red-500 font-bold">34</span>
                <span class="w-2.5 h-2.5 bg-red-600 rounded-full inline-block mr-2 select-none shrink-0"></span>
                <span>if (b.amount &gt;= o.total) &lbrace;</span>
              </div>
              <div class="px-4 text-zinc-500"><span class="w-6 inline-block select-none">35</span>     deduct(o.userId, o.total);</div>
              <div class="px-4 text-zinc-500"><span class="w-6 inline-block select-none">36</span>   &rbrace;</div>
            </div>
          </div>

          <p class="text-zinc-500 text-xs sm:text-sm font-light leading-relaxed text-center px-2">
            Incident fires → open VS Code → click to set a live breakpoint. No redeploy. No restart.
          </p>

          <!-- Bottom check badge -->
          <div class="rounded-lg border border-emerald-100 bg-emerald-50/40 text-[#0F766E] py-2 text-center text-xs font-bold font-sans">
            ✓ No redeploy. No restart.
          </div>
        </div>
      </div>

      <!-- Step 3: Snapshot Captured -->
      <div class="rounded-[20px] border border-zinc-200 bg-white overflow-hidden shadow-sm flex flex-col justify-between min-h-[540px] pb-6">
        <!-- Orange-red Header -->
        <div class="bg-[#C0392B] py-3.5 text-center">
          <span class="text-white font-mono font-bold tracking-widest text-[11px] uppercase">
            STEP 03
          </span>
        </div>

        <div class="p-6 flex flex-col justify-between flex-grow space-y-6">
          <h3 class="text-xl font-bold text-zinc-900 font-serif text-center mt-1">
            Snapshot Captured
          </h3>

          <!-- Visual: Variables snapshot mockup card -->
          <div class="rounded-[12px] border border-zinc-200 bg-zinc-50/30 overflow-hidden text-left font-mono text-[10px] leading-relaxed shadow-xs flex flex-col justify-between flex-grow">
            <!-- Header (pink bg) -->
            <div class="bg-[#FFF5F5] border-b border-zinc-200/50 p-2.5 select-none">
              <p class="text-[#C0392B] font-bold text-[10px] uppercase tracking-wide">SNAPSHOT — line 34 · 14:23:07 UTC</p>
              <p class="text-zinc-400 text-[9px] font-light mt-0.5">Thread not paused · Zero user impact</p>
            </div>
            <!-- Variables & Stack content -->
            <div class="p-3 space-y-2 flex-grow bg-white">
              <div>
                <span class="text-blue-600 font-bold block text-[9px] uppercase tracking-wide mb-1 font-sans">VARIABLES</span>
                <div class="space-y-0.5 text-zinc-600">
                  <p>b.amount = <span class="text-red-600 font-semibold">null</span></p>
                  <p>o.total = <span class="text-emerald-600 font-semibold">299.99</span></p>
                  <p>o.userId = <span class="text-amber-700 font-semibold">'usr_9182'</span></p>
                </div>
              </div>
              <div class="border-t border-zinc-100 pt-2">
                <span class="text-blue-600 font-bold block text-[9px] uppercase tracking-wide mb-1 font-sans">STACK TRACE</span>
                <p class="text-zinc-500 text-[9px] font-mono leading-normal">
                  process():34 → handleRequest():112
                </p>
              </div>
            </div>
          </div>

          <p class="text-zinc-500 text-xs sm:text-sm font-light leading-relaxed text-center px-2">
            When the breakpoint is hit by a real request, Hyperprobe captures the full state without pausing the thread.
          </p>

          <!-- Bottom check badge -->
          <div class="rounded-lg border border-emerald-100 bg-emerald-50/40 text-[#0F766E] py-2 text-center text-xs font-bold font-sans">
            ✓ Zero impact on live traffic
          </div>
        </div>
      </div>

    </div>

  </div>
</section>
