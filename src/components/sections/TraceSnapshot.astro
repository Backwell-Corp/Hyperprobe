---
// src/components/sections/TraceSnapshot.astro
---

<section id="trace-snapshot" class="relative z-10 bg-white">
  <div class="max-w-[1380px] mx-auto px-6 py-16 md:px-16 md:py-[100px]">
    
    <!-- Section Heading -->
    <div class="text-left max-w-5xl mb-16">
      <span class="eyebrow block mb-3">— AI DIAGNOSIS</span>
      <h2 class="section-heading mb-4">
        Snapshot captured.<br class="hidden sm:inline" />
        <span class="accent">Root cause in the same thread.</span>
      </h2>
      <p class="body-text">
        Your coding agent flags the suspect line. The SDK probes, captures the variable state, and hands it back. Your agent diagnoses, scopes the blast radius, and proposes a fix you can verify before merging. <span class="text-brand-primary font-medium">One conversation. One fix that works.</span>
      </p>
    </div>

    <!-- Side-by-Side Visual Panel -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-8 items-stretch">
      
      <!-- Snapshot Variables Card (Left 5 cols) -->
      <div class="lg:col-span-5 rounded-[20px] border-2 border-[#E0533C] bg-white overflow-hidden shadow-sm flex flex-col justify-between font-mono text-[12px] text-zinc-700">
        
        <!-- Snapshot Header Row -->
        <div class="p-4 border-b border-zinc-100">
          <div class="flex items-center gap-2 mb-1 text-[#E0533C] font-bold text-xs uppercase tracking-wider">
            <span class="w-2.5 h-2.5 rounded-full bg-[#E0533C] inline-block shrink-0"></span>
            <span>SNAPSHOT — line 34 · 14:23:07 UTC</span>
          </div>
          <p class="text-zinc-400 font-mono text-[10px]">Thread not paused · Zero user impact</p>
        </div>

        <!-- VARIABLES Section Header -->
        <div class="px-4 pt-3 pb-1">
          <span class="text-blue-600 font-bold text-[10px] uppercase tracking-wider block font-sans">VARIABLES</span>
        </div>

        <!-- VARIABLES list -->
        <div class="px-4 pb-3 space-y-1.5">
          <p class="text-zinc-700">user.tier = <span class="text-blue-600 font-semibold">'free'</span></p>
          <p class="text-zinc-700">amount = <span class="text-emerald-600 font-semibold">299.99</span></p>
        </div>

        <!-- balance Row (pink bg) -->
        <div class="px-4 py-2.5 border-y border-zinc-100 bg-[#FFF5F5]">
          <p class="text-zinc-700">
            balance = <span class="text-red-600 font-semibold">None</span> <span class="text-zinc-400 italic text-[10px] ml-1">← null silently</span>
          </p>
        </div>

        <!-- DB STATE Section Header -->
        <div class="px-4 pt-3 pb-1">
          <span class="text-blue-600 font-bold text-[10px] uppercase tracking-wider block font-sans">DB STATE</span>
        </div>

        <!-- db_conn Row (pink bg) -->
        <div class="px-4 py-2.5 border-y border-zinc-100 bg-[#FFF5F5]">
          <p class="text-zinc-700">
            db_conn = <span class="text-red-600 font-semibold">timeout (3,000ms)</span>
          </p>
        </div>

        <!-- db.pool.active Row (orangey bg) -->
        <div class="px-4 py-2.5 border-b border-zinc-100 bg-[#FFF9F5]">
          <p class="text-zinc-700">
            db.pool.active = <span class="text-amber-700 font-semibold">5 / 5 in use</span>
          </p>
        </div>

        <!-- db.pool.waiting Row (orangey bg) -->
        <div class="px-4 py-2.5 bg-[#FFF9F5]">
          <p class="text-zinc-700">
            db.pool.waiting = <span class="text-amber-700 font-semibold">12 queued</span>
          </p>
        </div>

      </div>

      <!-- AI Root Cause Console (Right 7 cols) -->
      <div class="lg:col-span-7 rounded-[20px] border border-zinc-200 bg-[#FCFCFD] overflow-hidden shadow-sm flex flex-col justify-between">
        
        <!-- Window Title Bar -->
        <div class="bg-[#1E293B] px-4.5 py-2.5 flex items-center gap-3">
          <div class="flex gap-1.5 shrink-0">
            <span class="w-2.5 h-2.5 rounded-full bg-[#EF4444] inline-block"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-[#F59E0B] inline-block"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-[#10B981] inline-block"></span>
          </div>
          <div class="mx-auto text-zinc-400 font-mono text-[9px] tracking-wider select-none pr-8">
            Hyperprobe AI · payment-service · INC-20240312-0047
          </div>
        </div>

        <!-- Chat Container / Console Body -->
        <div class="p-5 md:p-6 space-y-4 text-xs font-sans flex-grow">
          
          <!-- Message 1: AI response -->
          <div class="flex items-start gap-3">
            <div class="w-7 h-7 rounded-none bg-[#C0392B] flex items-center justify-center text-white text-[10px] font-bold font-mono shrink-0 select-none">
              AI
            </div>
            <div class="bg-white border border-zinc-200 p-3.5 shadow-xs flex-grow max-w-xl">
              <p class="text-zinc-800 text-[12px] leading-relaxed">
                <span class="font-semibold text-zinc-950 font-mono">get_balance()</span> returns <code class="bg-zinc-100 text-zinc-800 font-mono px-1 py-0.5 rounded text-[10px] font-semibold">None</code> on DB timeout — the free-tier connection pool is saturated (5/5 slots). The code silently treats <code class="bg-zinc-100 text-zinc-800 font-mono px-1 py-0.5 rounded text-[10px] font-semibold">None</code> as zero balance and throws <code class="bg-zinc-100 text-zinc-800 font-mono px-1 py-0.5 rounded text-[10px] font-semibold">InsufficientFunds</code>. Users see the wrong error. Paid-tier pool is separate and unaffected.
              </p>
            </div>
          </div>

          <!-- Message 2: DEV prompt -->
          <div class="flex items-start justify-end gap-3">
            <div class="bg-[#F3F4F6] border border-zinc-200/60 px-4 py-2 text-zinc-700 text-[12px] shadow-xs max-w-md">
              How many users affected?
            </div>
            <div class="w-7 h-7 rounded-none bg-[#1E293B] flex items-center justify-center text-white text-[10px] font-bold font-mono shrink-0 select-none">
              DEV
            </div>
          </div>

          <!-- Message 3: AI report -->
          <div class="flex items-start gap-3">
            <div class="w-7 h-7 rounded-none bg-[#C0392B] flex items-center justify-center text-white text-[10px] font-bold font-mono shrink-0 select-none">
              AI
            </div>
            <div class="bg-white border border-zinc-200 p-4 shadow-xs flex-grow max-w-xl space-y-3">
              <div class="text-[9px] font-bold tracking-wider text-zinc-400 font-mono border-b border-zinc-100 pb-1.5 block">
                ROOT CAUSE REPORT · MTTR: 9 MIN
              </div>
              <div class="space-y-2.5">
                
                <!-- CAUSE row -->
                <div class="flex items-start gap-3 text-[11px] leading-relaxed">
                  <span class="border border-red-200 bg-red-50 text-[#C0392B] px-1 py-0.5 font-bold font-mono text-[8px] uppercase tracking-wide shrink-0">
                    CAUSE
                  </span>
                  <p class="text-zinc-600">
                    847 failures · 89% free-tier · pool exhausted → null → wrong error shown
                  </p>
                </div>

                <!-- FIX row -->
                <div class="flex items-start gap-3 text-[11px] leading-relaxed">
                  <span class="border border-emerald-200 bg-emerald-50 text-emerald-700 px-1 py-0.5 font-bold font-mono text-[8px] uppercase tracking-wide shrink-0">
                    FIX
                  </span>
                  <p class="text-zinc-600">
                    Pool 5→20. Raise <code class="bg-zinc-100 text-zinc-800 font-mono px-1 py-0.5 rounded text-[10px] font-semibold">DBTimeoutException</code> explicitly, don't return <code class="bg-zinc-100 text-zinc-800 font-mono px-1 py-0.5 rounded text-[10px] font-semibold">None</code>.
                  </p>
                </div>

                <!-- PREVENT row -->
                <div class="flex items-start gap-3 text-[11px] leading-relaxed">
                  <span class="border border-blue-200 bg-blue-50 text-blue-700 px-1 py-0.5 font-bold font-mono text-[8px] uppercase tracking-wide shrink-0">
                    PREVENT
                  </span>
                  <p class="text-[#3F3F46]">
                    Circuit breaker on balance endpoint. Alert at pool > 80%.
                  </p>
                </div>

              </div>
            </div>
          </div>

        </div>

      </div>

    </div>

  </div>
</section>
