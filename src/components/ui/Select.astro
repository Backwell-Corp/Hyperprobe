---
// src/components/ui/Select.astro
import type { HTMLAttributes } from 'astro/types';

interface Option {
  value: string;
  label: string;
}

interface Props extends HTMLAttributes<'select'> {
  label: string;
  id: string;
  options: Option[];
  error?: string;
  helperText?: string;
  placeholder?: string;
}

const {
  label,
  id,
  options,
  error,
  helperText,
  placeholder = 'Select an option',
  class: className = '',
  required,
  ...rest
} = Astro.props;
---

<div class="flex flex-col gap-2 w-full">
  <div class="flex justify-between items-baseline">
    <label 
      for={id} 
      class="text-xs font-semibold uppercase tracking-wider text-zinc-500"
    >
      {label} {required && <span class="text-brand-primary" aria-hidden="true">*</span>}
    </label>
    {error && (
      <span class="text-xs font-medium text-accent-rose" id={`${id}-error`} role="alert">
        {error}
      </span>
    )}
  </div>

  <div class="relative w-full">
    <select
      id={id}
      required={required}
      aria-invalid={error ? 'true' : 'false'}
      aria-describedby={
        error 
          ? `${id}-error` 
          : helperText 
            ? `${id}-helper` 
            : undefined
      }
      class:list={[
        "w-full px-4 py-3 bg-white border rounded-lg text-sm text-zinc-800 transition-all duration-200 outline-none appearance-none cursor-pointer pr-10",
        error 
          ? "border-accent-rose/60 focus:border-accent-rose focus:ring-1 focus:ring-accent-rose" 
          : "border-zinc-200 focus:border-brand-primary focus:ring-1 focus:ring-brand-primary",
        className
      ]}
      {...rest}
    >
      {placeholder && (
        <option value="" disabled selected={!rest.value}>
          {placeholder}
        </option>
      )}
      {options.map((opt) => (
        <option value={opt.value} selected={rest.value === opt.value}>
          {opt.label}
        </option>
      ))}
    </select>
    
    <!-- Custom Dropdown Icon Indicator -->
    <div class="absolute right-3.5 top-1/2 -translate-y-1/2 pointer-events-none text-zinc-400">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </div>

  {helperText && !error && (
    <p class="text-xs text-zinc-400" id={`${id}-helper`}>
      {helperText}
    </p>
  )}
</div>
